    // State
    let currentFilter = 'all';
    let currentPage = 1;
    const perPage = 5;

    // Render entries
    function renderEntries() {
      const container = document.getElementById('entriesContainer');
      const searchTerm = document.getElementById('searchInput').value.trim();
      
      let filtered = mockData;

      if (currentFilter !== 'all') {
        filtered = filtered.filter(e => e.category === currentFilter);
      }

      if (searchTerm) {
        const parts = searchTerm.split('/');
        if (parts.length === 3) {
          const formatted = `${parts[0].padStart(2,'0')}/${parts[1].padStart(2,'0')}/${parts[2]}`;
          filtered = filtered.filter(e => e.date === formatted);
        } else {
          filtered = filtered.filter(e => 
            e.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
            e.excerpt.toLowerCase().includes(searchTerm.toLowerCase()) ||
            e.date.includes(searchTerm)
          );
        }
      }

      if (filtered.length === 0) {
        container.innerHTML = '';
        document.getElementById('emptyState').style.display = 'block';
        document.getElementById('entriesCount').textContent = '0 giriş';
        document.getElementById('pagination').innerHTML = '';
        return;
      }

      document.getElementById('emptyState').style.display = 'none';

      const totalPages = Math.ceil(filtered.length / perPage);
      const start = (currentPage - 1) * perPage;
      const paged = filtered.slice(start, start + perPage);

      document.getElementById('entriesCount').textContent = `${filtered.length} giriş bulundu`;

      container.innerHTML = paged.map((entry, idx) => `
        <div class="entry-card" style="animation-delay: ${idx * 0.08}s" onclick="openModal(${entry.id})">
          <div class="entry-meta">
            <span class="entry-date">${entry.date}</span>
            <span class="entry-source">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              ${entry.source}
            </span>
            <span class="entry-category cat-${entry.category}">${entry.categoryLabel}</span>
          </div>
          <h3 class="entry-title">${entry.title}</h3>
          <p class="entry-excerpt">${entry.excerpt}</p>
          <div class="entry-tags">
            ${entry.tags.map(t => `<span class="entry-tag">#${t}</span>`).join('')}
          </div>
          <div class="entry-actions">
            <button class="action-btn" onclick="event.stopPropagation(); likeEntry(${entry.id})">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              ${entry.likes}
            </button>
            <button class="action-btn" onclick="event.stopPropagation(); shareEntry(${entry.id})">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
              ${entry.shares}
            </button>
            <button class="action-btn" onclick="event.stopPropagation(); copyEntry(${entry.id})">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              Kopyala
            </button>
          </div>
        </div>
      `).join('');

      // Pagination
      const paginationEl = document.getElementById('pagination');
      if (totalPages <= 1) {
        paginationEl.innerHTML = '';
        return;
      }

      let pagHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        pagHTML += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
      }
      paginationEl.innerHTML = pagHTML;
    }

    // Search
    function searchEntries() {
      currentPage = 1;
      renderEntries();
    }

    document.getElementById('searchInput').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') searchEntries();
    });

    // Filter
    function filterBy(category, el) {
      currentFilter = category;
      currentPage = 1;
      document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
      el.classList.add('active');
      renderEntries();
    }

    // Pagination
    function goToPage(page) {
      currentPage = page;
      renderEntries();
      window.scrollTo({ top: 400, behavior: 'smooth' });
    }

    // Modal
    function openModal(id) {
      const entry = mockData.find(e => e.id === id);
      if (!entry) return;

      document.getElementById('modalBody').innerHTML = `
        <div class="entry-meta" style="margin-bottom:20px">
          <span class="entry-date">${entry.date}</span>
          <span class="entry-category cat-${entry.category}">${entry.categoryLabel}</span>
          <span class="entry-source">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
            ${entry.source}
          </span>
        </div>
        <h2>${entry.title}</h2>
        <div class="modal-content">
          ${entry.content.split('\n').map(p => p.trim() ? `<p>${p}</p>` : '').join('')}
        </div>
        <div class="entry-tags" style="margin-top:24px">
          ${entry.tags.map(t => `<span class="entry-tag">#${t}</span>`).join('')}
        </div>
      `;

      document.getElementById('modalOverlay').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(e) {
      if (e && e.target !== document.getElementById('modalOverlay') && e.target.closest('.modal-close')) {
        // direct close
      }
      document.getElementById('modalOverlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Actions
    function likeEntry(id) {
      const entry = mockData.find(e => e.id === id);
      if (entry) {
        entry.likes++;
        renderEntries();
        showToast('❤️ Beğenildi!');
      }
    }

    function shareEntry(id) {
      const entry = mockData.find(e => e.id === id);
      if (entry) {
        entry.shares++;
        renderEntries();
        showToast('🔗 Paylaşım linki kopyalandı!');
      }
    }

    function copyEntry(id) {
      const entry = mockData.find(e => e.id === id);
      if (entry) {
        navigator.clipboard.writeText(entry.excerpt).then(() => {
          showToast('📋 Panoya kopyalandı!');
        }).catch(() => {
          showToast('❌ Kopyalanamadı');
        });
      }
    }

    // Toast
    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2500);
    }

    // Init
    renderEntries();
  </script>
</body>
